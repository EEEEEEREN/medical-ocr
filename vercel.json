{
  "builds": [
    {
      "src": "api/app.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/ocr",
      "destination": "/api/app"
    },
    {
      "source": "/translate",
      "destination": "/api/app"
    },
    {
      "source": "/",
      "destination": "/api/app"
    }
  ]
}
